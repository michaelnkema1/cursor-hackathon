# Supabase (service role on server only — never expose to the browser)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Same JWT secret as Supabase project (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=

# Set to false if local tokens fail audience verification
SUPABASE_JWT_VERIFY_AUD=true

# Storage bucket for report media (teammate creates bucket + policies)
SUPABASE_STORAGE_BUCKET=reports

# Signed download URL lifetime (seconds)
STORAGE_SIGN_READ_TTL_SECONDS=3600

# Gemini (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

KHAYA_API_BASE_URL=https://translation.ghananlp.org
KHAYA_API_KEY=
KHAYA_TRANSLATE_PATH=/translate
KHAYA_TRANSCRIBE_PATH=https://translation-api.ghananlp.org/asr/v2/transcribe?language={language}
KHAYA_TARGET_LANGUAGE=en
KHAYA_TIMEOUT_SECONDS=30

# CORS — comma-separated origins, or * for hackathon demos
CORS_ORIGINS=http://localhost:3000

# development | production (hides internal error messages when production)
ENVIRONMENT=development

# AI: run Gemini in the same request as POST /reports (recommended for Vercel demo).
# If false, use POST /internal/process-issue/{id} with X-Internal-Key (e.g. Supabase webhook).
AI_INLINE=true
# Unreliable on some serverless; optional second HTTP invocation to /internal/process-issue
AI_TRIGGER_SELF_HTTP=false
APP_BASE_URL=
INTERNAL_PROCESS_SECRET=
